# Token do bot - Discord Developer Portal > Bot > Reset Token
DISCORD_TOKEN=

# Application ID - Discord Developer Portal > General Information > Application ID
DISCORD_CLIENT_ID=

# ID do servidor (ative o Modo Desenvolvedor no Discord, clique direito no servidor > Copiar ID)
DISCORD_GUILD_ID=

# ID da categoria onde os canais de ticket serão criados
DISCORD_CATEGORY_ID=

# (Opcional) ID da role de moderação que deve ver os canais de ticket
DISCORD_AUTHORIZED_ROLE_ID=

# URL do endpoint do PDA
PDA_API_URL=https://pda-free-stalker.vercel.app/api/discord-report

# Mesmo valor configurado como DISCORD_WEBHOOK_SECRET no Vercel
PDA_WEBHOOK_SECRET=
